index 0000000..ea1b715
--- /dev/null
+++ b/contrib/pgvector/bench/run_ivfflat_benchmark.sh
@@ -0,0 +1,266 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+SQL_FILE="${SCRIPT_DIR}/ivfflat_benchmark.sql"
+RESULT_DIR="${SCRIPT_DIR}/results"
+
+DBNAME="${DBNAME:-postgres}"
+ROWS="${ROWS:-10000}"
+DIMS="${DIMS:-128}"
+QUERIES="${QUERIES:-20}"
+TOPK="${TOPK:-10}"
+LISTS="${LISTS:-100}"
+PROBES_LIST="${PROBES_LIST:-1 4 10 32 100}"
+METRICS="${METRICS:-l2 ip cosine}"
+MAINTENANCE_WORK_MEM="${MAINTENANCE_WORK_MEM:-512MB}"
+OUTPUT="${OUTPUT:-${RESULT_DIR}/ivfflat_benchmark_$(date +%Y%m%d_%H%M%S).csv}"
+PLAN_OUTPUT="${PLAN_OUTPUT:-${OUTPUT%.csv}_plans.txt}"
+
+mkdir -p "$RESULT_DIR"
+TMP_DIR="$(mktemp -d)"
+ITEMS_FILE="${TMP_DIR}/items.csv"
+QUERIES_FILE="${TMP_DIR}/queries.csv"
+RUN_SQL_FILE="${TMP_DIR}/ivfflat_benchmark.sql"
+trap 'rm -rf "$TMP_DIR"' EXIT
+
+psql_cmd() {
+	psql -X -qAt -d "$DBNAME" "$@"
+}
+
+generate_vectors() {
+	local count="$1"
+	local dim="$2"
+	local seed="$3"
+	local output_file="$4"
+
+	awk -v count="$count" -v dim="$dim" -v seed="$seed" '
+		BEGIN {
+			srand(seed)
+			for (i = 1; i <= count; i++) {
+				printf "%d,\"[", i
+				for (j = 1; j <= dim; j++) {
+					if (j > 1)
+						printf ","
+					printf "%.8f", rand() + 0.000001
+				}
+				printf "]\"\n"
+			}
+		}
+	' > "$output_file"
+}
+
+metric_operator() {
+	case "$1" in
+		l2) echo "<->" ;;
+		ip) echo "<#>" ;;
+		cosine) echo "<=>" ;;
+		*) echo "unsupported metric: $1" >&2; return 1 ;;
+	esac
+}
+
+metric_opclass() {
+	case "$1" in
+		l2) echo "vector_l2_ops" ;;
+		ip) echo "vector_ip_ops" ;;
+		cosine) echo "vector_cosine_ops" ;;
+		*) echo "unsupported metric: $1" >&2; return 1 ;;
+	esac
+}
+
+write_header() {
+	printf '%s\n' "metric,rows,dims,queries,topk,lists,probes,avg_latency_ms,p95_latency_ms,recall_at_k,exact_avg_latency_ms" > "$OUTPUT"
+	{
+		printf 'pgvector IVFFlat benchmark plans\n'
+		printf 'rows=%s dims=%s queries=%s topk=%s lists=%s maintenance_work_mem=%s probes="%s" metrics="%s"\n\n' \
+			"$ROWS" "$DIMS" "$QUERIES" "$TOPK" "$LISTS" "$MAINTENANCE_WORK_MEM" "$PROBES_LIST" "$METRICS"
+	} > "$PLAN_OUTPUT"
+}
+
+setup_metric() {
+	local metric="$1"
+	local opclass
+	opclass="$(metric_opclass "$metric")"
+
+	sed \
+		-e "s#__ITEMS_FILE__#${ITEMS_FILE}#g" \
+		"$SQL_FILE" > "$RUN_SQL_FILE"
+
+	psql -X -q -d "$DBNAME" \
+		-v dims="$DIMS" \
+		-v lists="$LISTS" \
+		-v opclass="$opclass" \
+		-v maintenance_work_mem="$MAINTENANCE_WORK_MEM" \
+		-f "$RUN_SQL_FILE" >/dev/null
+}
+
+capture_plan() {
+	local metric="$1"
+	local operator="$2"
+	local opclass
+	local first_probes
+	local qid
+	local vector
+
+	opclass="$(metric_opclass "$metric")"
+	first_probes="$(printf '%s\n' $PROBES_LIST | head -n 1)"
+	IFS=, read -r qid vector < "$QUERIES_FILE"
+	vector="${vector#\"}"
+	vector="${vector%\"}"
+
+	{
+		printf '== metric=%s opclass=%s operator=%s lists=%s probes=%s query_id=%s ==\n' \
+			"$metric" "$opclass" "$operator" "$LISTS" "$first_probes" "$qid"
+		psql -X -q -d "$DBNAME" -v ON_ERROR_STOP=1 -c \
+			"SET enable_seqscan = off; SET ivfflat.probes = ${first_probes}; EXPLAIN (COSTS OFF) SELECT id FROM pgvector_bench.items ORDER BY embedding ${operator} '${vector}' LIMIT ${TOPK};"
+		printf '\n'
+	} >> "$PLAN_OUTPUT"
+}
+
+ids_for_query() {
+	local operator="$1"
+	local vector="$2"
+	local mode="$3"
+	local probes="${4:-}"
+	local settings
+
+	if [ "$mode" = "exact" ]; then
+		settings="SET enable_indexscan = off; SET enable_bitmapscan = off; SET enable_seqscan = on;"
+	else
+		settings="SET enable_seqscan = off; SET ivfflat.probes = ${probes};"
+	fi
+
+	psql_cmd -c "${settings} SELECT id FROM pgvector_bench.items ORDER BY embedding ${operator} '${vector}' LIMIT ${TOPK};" |
+		awk 'NF { print $1 }'
+}
+
+measure_query() {
+	local operator="$1"
+	local vector="$2"
+	local mode="$3"
+	local probes="${4:-}"
+	local output_file="$5"
+	local started_at finished_at elapsed_ns
+
+	started_at="$(date +%s%N)"
+	ids_for_query "$operator" "$vector" "$mode" "$probes" > "$output_file"
+	finished_at="$(date +%s%N)"
+	elapsed_ns=$((finished_at - started_at))
+	awk -v ns="$elapsed_ns" 'BEGIN { printf "%.3f", ns / 1000000.0 }'
+}
+
+recall_for_ids() {
+	local exact_file="$1"
+	local approx_file="$2"
+
+	awk -v k="$TOPK" '
+		NR == FNR {
+			exact[$1] = 1
+			next
+		}
+		($1 in exact) {
+			hits++
+		}
+		END {
+			printf "%.6f", hits / k
+		}
+	' "$exact_file" "$approx_file"
+}
+
+summarize_values() {
+	local values_file="$1"
+
+	awk '
+		{ values[++n] = $1; sum += $1 }
+		END {
+			if (n == 0) {
+				printf "0.000,0.000"
+				exit
+			}
+			for (i = 1; i <= n; i++) {
+				for (j = i + 1; j <= n; j++) {
+					if (values[i] > values[j]) {
+						tmp = values[i]; values[i] = values[j]; values[j] = tmp
+					}
+				}
+			}
+			p95_index = int(n * 0.95)
+			if (p95_index < 1)
+				p95_index = 1
+			if (p95_index < n && p95_index / n < 0.95)
+				p95_index++
+			printf "%.3f,%.3f", sum / n, values[p95_index]
+		}
+	' "$values_file"
+}
+
+run_probe_case() {
+	local metric="$1"
+	local probes="$2"
+	local operator="$3"
+	local exact_latencies="${TMP_DIR}/${metric}_exact.lat"
+	local approx_latencies="${TMP_DIR}/${metric}_${probes}_approx.lat"
+	local recalls="${TMP_DIR}/${metric}_${probes}.recall"
+	local approx_ids="${TMP_DIR}/approx.ids"
+
+	: > "$approx_latencies"
+	: > "$recalls"
+
+	echo "==> metric=${metric} rows=${ROWS} dims=${DIMS} lists=${LISTS} probes=${probes}"
+
+	while IFS=, read -r qid vector; do
+		vector="${vector#\"}"
+		vector="${vector%\"}"
+
+		measure_query "$operator" "$vector" approx "$probes" "$approx_ids" >> "$approx_latencies"
+		printf '\n' >> "$approx_latencies"
+		recall_for_ids "${TMP_DIR}/${metric}_exact_${qid}.ids" "$approx_ids" >> "$recalls"
+		printf '\n' >> "$recalls"
+	done < "$QUERIES_FILE"
+
+	local approx_summary exact_summary recall_avg
+	approx_summary="$(summarize_values "$approx_latencies")"
+	exact_summary="$(summarize_values "$exact_latencies")"
+	recall_avg="$(awk '{ sum += $1; n++ } END { if (n == 0) printf "0.0000"; else printf "%.4f", sum / n }' "$recalls")"
+
+	printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
+		"$metric" "$ROWS" "$DIMS" "$QUERIES" "$TOPK" "$LISTS" "$probes" "$approx_summary" "$recall_avg" "$(echo "$exact_summary" | cut -d, -f1)" >> "$OUTPUT"
+}
+
+prepare_exact_results() {
+	local metric="$1"
+	local operator="$2"
+	local exact_latencies="${TMP_DIR}/${metric}_exact.lat"
+
+	: > "$exact_latencies"
+
+	echo "==> metric=${metric} rows=${ROWS} dims=${DIMS} exact baseline"
+
+	while IFS=, read -r qid vector; do
+		vector="${vector#\"}"
+		vector="${vector%\"}"
+
+		measure_query "$operator" "$vector" exact "" "${TMP_DIR}/${metric}_exact_${qid}.ids" >> "$exact_latencies"
+		printf '\n' >> "$exact_latencies"
+	done < "$QUERIES_FILE"
+}
+
+write_header
+generate_vectors "$ROWS" "$DIMS" 17 "$ITEMS_FILE"
+generate_vectors "$QUERIES" "$DIMS" 97 "$QUERIES_FILE"
+chmod 755 "$TMP_DIR"
