+    ('opentenbase_100k_128d_20260621', 'l2', 100000, 128, 10, 1000, 1000, 56.440, 58.867, 1.0000, 41.951),
+    ('opentenbase_100k_128d_20260621', 'ip', 100000, 128, 10, 1000, 1, 12.398, 13.287, 0.0100, 40.791),
