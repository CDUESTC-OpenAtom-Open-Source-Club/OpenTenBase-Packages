+    ('opentenbase_100k_128d_20260621', 'cosine', 100000, 128, 10, 1000, 1000, 57.717, 59.441, 1.0000, 42.526);
+
+CREATE OR REPLACE FUNCTION pgvector_bench.recommend_ivfflat_params(
+    row_count bigint,
+    dims integer,
+    target_recall numeric DEFAULT 0.90,
+    metric text DEFAULT 'l2',
+    list_count integer DEFAULT NULL
+)
+RETURNS TABLE (
+    recommended_lists integer,
+    recommended_probes integer,
+    estimated_recall numeric,
+    expected_avg_latency_ms numeric,
+    maintenance_work_mem text,
+    recommendation_source text,
+    risk_level text,
+    rationale text
+)
+LANGUAGE plpgsql
+AS $$
+DECLARE
+    effective_lists integer;
+    probe_ratio numeric;
+    metric_factor numeric;
+    measured record;
+BEGIN
+    IF row_count <= 0 THEN
+        RAISE EXCEPTION 'row_count must be positive';
+    END IF;
+    IF dims <= 0 THEN
+        RAISE EXCEPTION 'dims must be positive';
+    END IF;
+    IF target_recall <= 0 OR target_recall > 1 THEN
+        RAISE EXCEPTION 'target_recall must be in (0, 1]';
+    END IF;
+    IF metric NOT IN ('l2', 'ip', 'cosine') THEN
+        RAISE EXCEPTION 'metric must be one of: l2, ip, cosine';
+    END IF;
+
+    effective_lists := COALESCE(
+        list_count,
+        GREATEST(10, LEAST(4096, (ROUND((SQRT(row_count::numeric) * CASE WHEN dims >= 128 THEN 3.2 ELSE 2.0 END) / 50.0) * 50)::integer))
+    );
+
+    SELECT *
+    INTO measured
+    FROM pgvector_bench.ivfflat_benchmark_observations o
+    WHERE o.metric = recommend_ivfflat_params.metric
+      AND o.rows = row_count
+      AND o.dims = recommend_ivfflat_params.dims
+      AND o.lists = effective_lists
+      AND o.recall_at_k >= target_recall
+    ORDER BY o.avg_latency_ms ASC, o.probes ASC
+    LIMIT 1;
+
+    IF FOUND THEN
+        recommended_lists := measured.lists;
+        recommended_probes := measured.probes;
+        estimated_recall := measured.recall_at_k;
+        expected_avg_latency_ms := measured.avg_latency_ms;
+        maintenance_work_mem := CASE
+            WHEN row_count * dims >= 51200000 THEN '1GB'
+            WHEN row_count * dims >= 6400000 THEN '512MB'
+            ELSE '128MB'
+        END;
+        recommendation_source := measured.source;
+        risk_level := CASE
+            WHEN measured.recall_at_k >= 0.95 THEN 'low'
+            WHEN measured.recall_at_k >= 0.90 THEN 'medium'
+            ELSE 'high'
+        END;
+        rationale := 'selected from measured OpenTenBase benchmark observations with the lowest average latency meeting target_recall';
+        RETURN NEXT;
+        RETURN;
+    END IF;
+
+    probe_ratio := CASE
+        WHEN target_recall >= 0.99 THEN 1.00
+        WHEN target_recall >= 0.95 THEN 0.75
+        WHEN target_recall >= 0.90 THEN 0.50
+        WHEN target_recall >= 0.80 THEN 0.30
+        ELSE 0.15
+    END;
+    metric_factor := CASE
+        WHEN metric = 'ip' THEN 1.15
+        ELSE 1.00
+    END;
+
+    recommended_lists := effective_lists;
+    recommended_probes := GREATEST(1, LEAST(effective_lists, CEIL(effective_lists * probe_ratio * metric_factor)::integer));
+    estimated_recall := NULL;
+    expected_avg_latency_ms := NULL;
+    maintenance_work_mem := CASE
+        WHEN row_count * dims >= 51200000 THEN '1GB'
+        WHEN row_count * dims >= 6400000 THEN '512MB'
+        ELSE '128MB'
+    END;
+    recommendation_source := 'heuristic';
+    risk_level := CASE
+        WHEN target_recall >= 0.95 THEN 'medium'
+        ELSE 'low'
+    END;
+    rationale := 'heuristic recommendation; run bench/run_ivfflat_benchmark.sh on representative data to validate recall and latency before production use';
+    RETURN NEXT;
+END;
+$$;
diff --git a/contrib/pgvector/bench/run_ivfflat_benchmark.sh b/contrib/pgvector/bench/run_ivfflat_benchmark.sh
