# OpenTenBase pg_hba.conf template
# WARNING: trust mode allows all connections without authentication.
# Only use trust for local/loopback connections in development/testing.
local   all             all                                     trust
host    all             all             127.0.0.1/32            trust
host    all             all             ::1/128                 trust
# Remote connections require password authentication (scram-sha-256)
host    all             all             0.0.0.0/0               scram-sha-256
