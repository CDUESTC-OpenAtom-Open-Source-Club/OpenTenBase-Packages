#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DBUILD_SHARED_LIBS=ON \
		-DSKIP_BUILD_TEST=ON

override_dh_makeshlibs:
	dh_makeshlibs -V"libpqxx-7.9 (>= 7.9.2)"