#!/usr/bin/make -f
OTB_VERSION := 5.0
PREFIX  := /usr/lib/opentenbase/$(OTB_VERSION)
DESTDIR := $(CURDIR)/debian/tmp
JOBS    := $(shell nproc)

# Suppress all warnings and force C17/C++17 (C23 breaks OpenTenBase: bool keyword, empty param lists)
export DEB_CFLAGS_MAINT_APPEND := -w -std=gnu17
export DEB_CXXFLAGS_MAINT_APPEND := -w -std=gnu++17
export DEB_LDFLAGS_MAINT_APPEND := -Wl,--allow-multiple-definition -Wl,-rpath,/usr/lib/opentenbase/$(OTB_VERSION)/lib

# Force system libraries (avoid conda paths)
export PATH := /usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PKG_CONFIG_PATH := /usr/lib/$(shell dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null || echo x86_64-linux-gnu)/pkgconfig:/usr/share/pkgconfig

%:
	dh $@

override_dh_auto_configure:
	# GCC 15+ (C23 default): bool is a keyword, MAXHOSTNAMELEN needs sys/param.h
	if [ -f src/test/thread/thread_test.c ]; then \
	    sed -i 's/typedef char bool;/#if !defined(__STDC_VERSION__) || __STDC_VERSION__ < 202311L\ntypedef _Bool bool;\n#endif/' src/test/thread/thread_test.c; \
	    sed -i '/#include <fcntl.h>/a #ifndef MAXHOSTNAMELEN\n#include <sys/param.h>\n#endif' src/test/thread/thread_test.c; \
	fi
	# Also patch configure to not fail on thread test — modern glibc IS thread-safe
	sed -i 's/as_fn_error \$? "thread test program failed/# as_fn_error \$? "thread test program failed/' configure; \
	sed -i 's/Use --disable-thread-safety to disable thread safety\." "\$LINENO" 5/# Use --disable-thread-safety.../' configure
	# GCC 15+ (C23 default): bool is a keyword, cannot be typedef'd
	# Also change 'typedef char bool' to 'typedef _Bool bool' so that bool
	# resolves to _Bool consistently (avoids conflict when system headers
	# pull in stdbool.h which #define bool _Bool, making _Bool* != char*)
	if grep -q 'typedef char bool;' src/include/c.h 2>/dev/null; then \
	    sed -i 's/typedef char bool;/#if !defined(__STDC_VERSION__) || __STDC_VERSION__ < 202311L\ntypedef _Bool bool;\n#endif/' src/include/c.h; \
	fi
	# Fix gtm_opt.c struct initializer
	if grep -q 'false, false, NULL' src/gtm/main/gtm_opt.c 2>/dev/null; then \
	    sed -i '/enable_gtm_resqueue_debug/,/},/{s/true, false, NULL/true, NULL, NULL, false, NULL/; s/false, false, NULL/false, NULL, NULL, false, NULL/}' src/gtm/main/gtm_opt.c; \
	fi
	# Fix CLI11 missing cstdint (uint64_t not found in newer GCC/libstdc++)
	for f in src/CLI/Validators.hpp \
	         contrib/opentenbase_tool/src/CLI/Validators.hpp \
	         contrib/opentenbase_ctl/src/CLI/Validators.hpp; do \
	    if [ -f "$$f" ]; then \
	        grep -q '#include <cstdint>' "$$f" || sed -i '/#include <sys\/stat\.h>/a #include <cstdint>' "$$f"; \
	    fi; \
	done
	# Fix hardcoded static library paths in configure
	sed -i 's|/usr/local/lib/liblz4.a|-llz4|g' configure
	sed -i 's|/usr/local/lib/libzstd.a|-lzstd|g' configure
	# Fix ldap_r deprecation (merged into ldap in modern OpenLDAP)
	sed -i 's/-lldap_r/-lldap/g' configure
	# Ensure libatomic.so symlink exists BEFORE configure (Ubuntu doesn't always have it)
	for dir in /usr/lib/x86_64-linux-gnu /usr/lib/aarch64-linux-gnu; do \
	    if [ -f "$$dir/libatomic.so.1" ] && [ ! -f "$$dir/libatomic.so" ]; then \
	        ln -sf libatomic.so.1 "$$dir/libatomic.so"; \
	    fi; \
	done
	./configure \
	    --prefix=$(PREFIX) \
	    --sysconfdir=/etc/opentenbase/$(OTB_VERSION) \
	    --datarootdir=$(PREFIX)/share \
	    --includedir=/usr/include/opentenbase/$(OTB_VERSION) \
	    --with-openssl \
	    --with-ldap \
	    --with-pam \
	    --with-libxml \
	    --with-readline \
	    --with-uuid=e2fs \
	    --with-lz4 \
	    --with-zstd \
	    --enable-license=no \
	    --enable-thread-safety \
	    XML2_CONFIG=/usr/bin/xml2-config \
	    CFLAGS="-O2 -g -fPIC -w -std=gnu17 -Wno-error=incompatible-pointer-types -Wno-error=int-conversion -Wno-error=implicit-function-declaration -Wno-error=implicit-int -DNOLIC -I/usr/include/libxml2 $(if $(filter amd64,$(shell dpkg-architecture -qDEB_HOST_ARCH 2>/dev/null)),-mcx16)" \
	    LDFLAGS="-L/usr/lib/$(shell dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null || echo x86_64-linux-gnu) -Wl,--allow-multiple-definition -Wl,-rpath,/usr/lib/opentenbase/$(OTB_VERSION)/lib -Wl,--no-as-needed -latomic" \
	    LIBS="-lpthread -lzstd -llz4 -Wl,--no-as-needed -latomic"
	# Patch LIBS and strip --as-needed
	sed -i 's|^LIBS = \(.*\)|LIBS = \1 -Wl,--no-as-needed -latomic|' src/Makefile.global
	sed -i 's/-Wl,--as-needed//g' src/Makefile.global

override_dh_auto_build:
	# Fix flex lex.backup race: replace the wc -l check + rm with simple rm -f
	# The original recipe fails when parallel flex removes lex.backup before wc reads it
	sed -i 's/if \[ `wc -l <lex\.backup` -eq 1 \]; then rm lex\.backup; else echo "Scanner requires backup; see lex\.backup\." 1>\&2; exit 1; fi/rm -f lex.backup/' src/Makefile.global
	# Pre-build libpq and generate objfiles.txt (race condition fix)
	# libpq's Makefile has 'all: all-lib' but doesn't generate objfiles.txt.
	# The postgres binary needs src/interfaces/libpq/objfiles.txt to link against libpq.
	$(MAKE) -j$(JOBS) -C src/interfaces/libpq all
	# Generate objfiles.txt listing libpq's compiled object files
	( cd src/interfaces/libpq && for f in *.o; do echo "src/interfaces/libpq/$$f"; done ) > src/interfaces/libpq/objfiles.txt
	# Now build everything in parallel
	$(MAKE) -j$(JOBS) all
	# Exclude uuid-ossp from contrib build (needs md5.h removed in OpenSSL 3.0)
	# We use --with-uuid=e2fs so uuid-ossp is not needed
	sed -i 's/ uuid-ossp//' contrib/Makefile
	# For v5.0+, opentenbase_ctl is MANDATORY — install any missing deps
	# For older versions (2.x), contrib/opentenbase_ctl does not exist upstream
	if [ "$(OTB_VERSION)" != "5.0" ]; then \
	    sed -i 's/ opentenbase_ctl//' contrib/Makefile; \
	    echo "NOTE: opentenbase_ctl not available in this version, skipping (v5.0+ only)"; \
	else \
	    echo "=== opentenbase_ctl: MANDATORY build (v5.0) ==="; \
	    if [ ! -f /usr/include/libssh2.h ] && [ ! -f /usr/local/include/libssh2.h ]; then \
	        echo "ERROR: libssh2 headers not found — opentenbase_ctl requires them"; \
	        exit 1; \
	    fi; \
	    if [ ! -f /usr/include/CLI/CLI.hpp ] && [ ! -f /usr/local/include/CLI/CLI.hpp ]; then \
	        echo "NOTE: CLI11 not found, installing single-header v2.4.2"; \
	        mkdir -p /usr/local/include/CLI; \
	        curl -fsSL https://github.com/CLIUtils/CLI11/releases/download/v2.4.2/CLI11.hpp \
	            -o /usr/local/include/CLI/CLI.hpp || { \
	            echo "ERROR: Failed to download CLI11"; exit 1; \
	        }; \
	    fi; \
	    if [ ! -d /usr/local/include/indicators ] && [ ! -d /usr/include/indicators ]; then \
	        echo "NOTE: indicators not found, installing from GitHub"; \
	        cd /tmp && rm -rf indicators_src; \
	        git clone --depth 1 https://github.com/p-ranav/indicators.git /tmp/indicators_src || { \
	            echo "ERROR: Failed to clone indicators"; exit 1; \
	        }; \
	        mkdir -p /usr/local/include/indicators; \
	        cp -r /tmp/indicators_src/include/indicators/* /usr/local/include/indicators/; \
	        cp /tmp/indicators_src/include/indicators.hpp /usr/local/include/ 2>/dev/null || true; \
	        rm -rf /tmp/indicators_src; \
	        echo "NOTE: indicators headers installed to /usr/local/include/indicators/"; \
	    fi; \
	    if [ ! -f /usr/include/pqxx/pqxx ] && [ ! -f /usr/local/include/pqxx/pqxx ]; then \
	        echo "NOTE: libpqxx not found, building 7.9.2 from source"; \
	        cd /tmp && rm -rf libpqxx-*; \
	        curl -fsSL https://github.com/jtv/libpqxx/archive/refs/tags/7.9.2.tar.gz -o /tmp/libpqxx.tar.gz || { \
	            echo "ERROR: Failed to download libpqxx"; exit 1; \
	        }; \
	        tar xzf /tmp/libpqxx.tar.gz -C /tmp; \
	        cd /tmp/libpqxx-7.9.2; \
	        cmake -B build -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_SHARED_LIBS=ON -DSKIP_BUILD_TEST=ON; \
	        cmake --build build -j$(JOBS); \
	        cmake --install build; \
	        cd /tmp && rm -rf libpqxx-* /tmp/libpqxx.tar.gz; \
	        ldconfig; \
	        echo "NOTE: libpqxx 7.9.2 built and installed"; \
	    fi; \
	fi
	$(MAKE) -j$(JOBS) -C contrib all
	# POST-BUILD VERIFICATION: opentenbase_ctl MUST exist for v5.0
	if [ "$(OTB_VERSION)" = "5.0" ] && [ ! -f contrib/opentenbase_ctl/opentenbase_ctl ]; then \
	    echo "============================================================"; \
	    echo "FATAL: opentenbase_ctl binary not found after contrib build!"; \
	    echo "Dependencies status:"; \
	    echo "  CLI11: $$(ls /usr/local/include/CLI/CLI.hpp /usr/include/CLI/CLI.hpp 2>/dev/null || echo MISSING)"; \
	    echo "  indicators: $$(ls -d /usr/local/include/indicators /usr/include/indicators 2>/dev/null || echo MISSING)"; \
	    echo "  libpqxx: $$(find /usr/include/pqxx/pqxx /usr/local/include/pqxx/pqxx 2>/dev/null || echo MISSING)"; \
	    echo "  libssh2: $$(ls /usr/include/libssh2.h 2>/dev/null || echo MISSING)"; \
	    echo "============================================================"; \
	    exit 1; \
	elif [ "$(OTB_VERSION)" = "5.0" ]; then \
	    echo "NOTE: opentenbase_ctl binary built successfully"; \
	fi

override_dh_auto_install:
	$(MAKE) -j$(JOBS) DESTDIR=$(DESTDIR) install
	$(MAKE) -j$(JOBS) DESTDIR=$(DESTDIR) -C contrib install
	# Create opentenbase-ctl symlink → official opentenbase_ctl binary
	mkdir -p $(DESTDIR)/usr/bin
	ln -sf $(PREFIX)/bin/opentenbase_ctl $(DESTDIR)/usr/bin/opentenbase-ctl
	# Bundle libpqxx.so into OpenTenBase lib dir (rpath already set to find it here)
	# This ensures opentenbase_ctl can find libpqxx at runtime without system package
	for libpath in /usr/lib/libpqxx.so /usr/lib/x86_64-linux-gnu/libpqxx.so /usr/lib/aarch64-linux-gnu/libpqxx.so /usr/local/lib/libpqxx.so; do \
	    if [ -f "$$libpath" ]; then \
	        cp -L "$$libpath" $(DESTDIR)$(PREFIX)/lib/; \
	        echo "Bundled $$libpath into package"; \
	        break; \
	    fi; \
	done
	install -D -m 0755 scripts/switch-version.sh $(DESTDIR)/usr/bin/opentenbase-switch-version
	# Select version-specific config template if available, otherwise use default
	if [ -f config/$(OTB_VERSION)/opentenbase.conf ]; then \
	    install -D -m 0644 config/$(OTB_VERSION)/opentenbase.conf $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/opentenbase.conf; \
	else \
	    install -D -m 0644 config/opentenbase.conf $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/opentenbase.conf; \
	fi
	install -D -m 0644 config/gtm.conf.template $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/gtm.conf.template
	install -D -m 0644 config/postgresql.conf.coord.template $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/postgresql.conf.coord.template
	install -D -m 0644 config/postgresql.conf.dn.template $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/postgresql.conf.dn.template
	install -D -m 0644 config/pg_hba.conf.template $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/pg_hba.conf.template
	# Install opentenbase_ctl config template
	if [ -f config/opentenbase_config.ini.example ]; then \
	    install -D -m 0644 config/opentenbase_config.ini.example $(DESTDIR)/etc/opentenbase/$(OTB_VERSION)/opentenbase_config.ini.example; \
	fi
	# Install raw SGML doc sources into doc package staging area
	mkdir -p $(DESTDIR)/usr/share/doc/opentenbase/sgml
	if [ -d doc/src/sgml ]; then \
	    find doc/src/sgml -maxdepth 1 -type f \( -name '*.sgml' -o -name '*.xml' \) -exec cp {} $(DESTDIR)/usr/share/doc/opentenbase/sgml/ \; ; \
	fi
	# Rename pg_config -> opentenbase_config public symlink (also keep private one)
	if [ -e $(DESTDIR)$(PREFIX)/bin/pg_config ]; then \
	    install -D -m 0755 $(DESTDIR)$(PREFIX)/bin/pg_config $(DESTDIR)/usr/bin/opentenbase_config; \
	fi
	# Create version marker file
	echo "$(OTB_VERSION)" > $(DESTDIR)$(PREFIX)/VERSION

override_dh_auto_test:
	true

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/debian/tmp$(PREFIX)/lib || true

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start

override_dh_install:
		# Dynamically replace hardcoded 5.0 version paths with actual version
		# debian/*.install files have hardcoded 5.0 paths; replace with $(OTB_VERSION)
		for f in debian/*.install; do \
		    if grep -q 'usr/lib/opentenbase/5.0' "$$f" 2>/dev/null; then \
		        sed -i 's|usr/lib/opentenbase/5.0|usr/lib/opentenbase/$(OTB_VERSION)|g' "$$f"; \
		        sed -i 's|etc/opentenbase/5.0|etc/opentenbase/$(OTB_VERSION)|g' "$$f"; \
		    fi; \
		done
		# Remove unbuilt binaries from .install files before dh_install runs
		for bin in opentenbase_ctl opentenbase_tool pg_license; do \
		    if [ ! -e debian/tmp$(PREFIX)/bin/$$bin ]; then \
		        sed -i "/$$bin/d" debian/*.install; \
		    fi; \
		done; \
		# Remove opentenbase-ctl symlink from .install if opentenbase_ctl wasn't built
		if [ ! -e debian/tmp$(PREFIX)/bin/opentenbase_ctl ]; then \
		    sed -i '/opentenbase-ctl/d' debian/*.install; \
		fi
		# For v2.6.0 and v2.5.0, skip files that don't exist in older versions
		if [ "$(OTB_VERSION)" != "5.0" ]; then \
		    dh_install \
		        -Xopentenbase_ora.bki \
		        -Xopentenbase_ora.description \
		        -Xopentenbase_ora.shdescription \
		        -Xsystem_views_opentenbase_ora.sql \
		        -Xsystem_views_pg.sql; \
		else \
		    dh_install; \
		fi

override_dh_installdocs:
	# v2.5.0 may not have CONTRIBUTORS.md; install what exists
	: > debian/opentenbase-doc.docs
	for f in README.md LICENSE.txt HISTORY CONTRIBUTORS.md; do \
	    [ -f "$$f" ] && echo "$$f" >> debian/opentenbase-doc.docs || true; \
	done
	dh_installdocs

override_dh_missing:
	dh_missing --list-missing

override_dh_auto_clean:
	if [ -f GNUmakefile ] || [ -f Makefile ]; then $(MAKE) distclean || true; fi
	rm -rf debian/tmp

override_dh_autoreconf:
	# OpenTenBase v5.0 ships configure for autoconf 2.69; do not regenerate
	true

override_dh_update_autotools_config:
	true
